# Binance API Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# =============================================================
# JPY→グリッド取引のルート（Binance.com 国際版）
# =============================================================
# Binance.com には JPY ペアがありません。
# 以下のルートで USDT を準備してください:
#
#   方法A: 日本の取引所→Binance
#     1. bitFlyer/Coincheck/GMO 等で JPY → BTC/ETH 購入
#     2. Binance.com へ BTC/ETH 送金
#     3. Binance スポットで BTC/ETH → USDT に変換
#     4. グリッド取引開始
#
#   方法B: Binance P2P
#     1. Binance P2P で銀行送金→USDT 購入
#     ※ スプレッドに注意
#
# プリセット設定を利用可能:
#   python main.py --list-presets          # 全プリセット表示
#   python main.py --recommend 300         # 300USDT向け推奨
#   python main.py --preset eth-balanced   # ETH バランス設定で起動
#   python main.py --preset sol-aggressive # SOL 積極設定で起動
# =============================================================

# Trading Settings
TRADING_SYMBOL=ETHUSDT
GRID_COUNT=10
LOWER_PRICE=
UPPER_PRICE=
INVESTMENT_AMOUNT=200
TRADING_FEE_RATE=0.001
GRID_RANGE_FACTOR=0.08

# Risk Management
STOP_LOSS_PERCENTAGE=10
MAX_DRAWDOWN_PCT=15
MAX_POSITIONS=5

# Bot Behavior
CHECK_INTERVAL=10
STATUS_DISPLAY_INTERVAL=60
MAX_CONSECUTIVE_ERRORS=5
CLOSE_ON_STOP=true

# Persistence
PERSIST_INTERVAL=60

# Use Testnet (true/false)
USE_TESTNET=true

# User stream via listenKey (true/false)
USE_USER_STREAM=true

# Production confirmation (required when USE_TESTNET=false in non-interactive env)
# CONFIRM_PRODUCTION=true
