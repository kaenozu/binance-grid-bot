# Binance API Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Settings
TRADING_SYMBOL=ETHUSDT
GRID_COUNT=10
LOWER_PRICE=
UPPER_PRICE=
INVESTMENT_AMOUNT=100
TRADING_FEE_RATE=0.001

# Risk Management
STOP_LOSS_PERCENTAGE=5
MAX_POSITIONS=5

# Bot Behavior
CHECK_INTERVAL=10
STATUS_DISPLAY_INTERVAL=60
MAX_CONSECUTIVE_ERRORS=5
GRID_RANGE_FACTOR=0.08
CLOSE_ON_STOP=true

# Persistence
PERSIST_INTERVAL=60

# Use Testnet (true/false)
USE_TESTNET=true
